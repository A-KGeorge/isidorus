{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src/ts",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@isidorus/core": ["../core/src/ts/index.ts"] // Point to source for robust resolution
    },
    "skipLibCheck": true
  },
  "include": ["src/ts/**/*"], // Update to match rootDir
  "references": [{ "path": "../core" }],
  "exclude": ["node_modules", "dist", "src/ts/**/*.test.ts"]
}
