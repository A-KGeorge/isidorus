{
    "name": "@isidorus/core",
    "version": "0.0.0-alpha.2",
    "description": "Shared types, tensor IR, and graph abstractions for isidorus",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsc",
        "build:watch": "tsc --watch",
        "test": "node scripts/test.js",
        "test:clean": "node -e \"require('fs').rmSync('./test/test.db', { force: true })\" && npm test",
        "test:install": "node scripts/test-install.js"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/A-KGeorge/isidorus.git"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true,
        "registry": "https://registry.npmjs.org/"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "tsx": "^4.0.0",
        "typescript": "^5.4.0"
    },
    "author": "Alan Kochukalam George",
    "license": "Apache-2.0"
}
