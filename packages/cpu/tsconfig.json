{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@isidorus/core": ["../core/src/ts/index.ts"],
      "@isidorus/core/*": ["../core/src/ts/*"]
    },
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "references": [{ "path": "../core" }],
  "exclude": ["node_modules", "dist", "src/**/*.test.ts"]
}
