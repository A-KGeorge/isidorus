{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["ES2024"],
    "outDir": "./dist",
    "rootDir": "./src/ts",
    "composite": true,
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "types": ["node"],
    "paths": {
      "@isidorus/core": ["../core/src/ts/index.ts"]
    },
    "skipLibCheck": true
  },
  "include": ["src/ts/**/*"], // Update to match rootDir
  "references": [{ "path": "../core" }],
  "exclude": ["node_modules", "dist", "src/ts/**/*.test.ts"]
}
